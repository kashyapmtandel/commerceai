<Layout
    title={"About Us | Commerce AI — UCP Compliance Checker"}
    description={"Learn about Commerce AI, the team behind the free UCP Compliance Checker tool for AI-powered agentic commerce."}
    canonical={"https://commerceai.online/about"}
