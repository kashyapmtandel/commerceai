---
import Layout from '../layouts/Layout.astro';
---

<Layout
    title={"Contact Us | Commerce AI — UCP Compliance Checker"}
    description={"Get in touch with Commerce AI. Questions, feedback, or partnership inquiries about the UCP Compliance Checker."}
    canonical={"https://commerceai.online/contact"}
    ogTitle={"Contact Us | Commerce AI"}
>
    <main>
        <section class="page-header">
                    <div class="orb orb-1"></div>
                    <div class="orb orb-2"></div>
                    <h1>Contact <span class="gradient-text">Us</span></h1>
                    <p>Have a question, suggestion, or partnership inquiry? We'd love to hear from you.</p>
                </section>

                <div class="page-body">
                    <h2>Get in Touch</h2>
                    <p>Whether you have questions about UCP compliance, need help interpreting your scan results, or want to report a bug, we're here to help. Fill out the form below or reach out directly via email.</p>

                    <form class="contact-form" id="contactForm" action="https://formsubmit.co/hello@commerceai.online" method="POST">
                        <input type="hidden" name="_subject" value="New Contact from Commerce AI">
                        <input type="hidden" name="_captcha" value="false">
                        <input type="hidden" name="_next" value="https://commerceai.online/contact?sent=true">
                        <input type="text" name="_honey" class="hidden-honey">

                        <div class="form-group">
                            <label for="name">Your Name</label>
                            <input type="text" id="name" name="name" placeholder="John Doe" required>
                        </div>

                        <div class="form-group">
                            <label for="email">Email Address</label>
                            <input type="email" id="email" name="email" placeholder="john@example.com" required>
                        </div>

                        <div class="form-group">
                            <label for="subject">Subject</label>
                            <input type="text" id="subject" name="subject" placeholder="Question about UCP compliance" required>
                        </div>

                        <div class="form-group">
                            <label for="message">Message</label>
                            <textarea id="message" name="message" placeholder="Tell us how we can help..." required></textarea>
                        </div>

                        <button type="submit" class="submit-btn">
                            Send Message
                        </button>
                    </form>

                    <div id="successMessage" class="success-message">
                        <p class="success-title">✅ Message Sent!</p>
                        <p class="success-text">Thank you for reaching out. We'll get back to you as soon as possible.</p>
                    </div>

                    <h2>Other Ways to Reach Us</h2>
                    <ul>
                        <li><strong>Email:</strong> <a href="mailto:hello@commerceai.online">hello@commerceai.online</a></li>
                        <li><strong>GitHub:</strong> <a href="https://github.com/google/ucp" target="_blank" rel="noopener">Report issues or contribute</a></li>
                        <li><strong>Website:</strong> <a href="https://commerceai.online">commerceai.online</a></li>
                    </ul>

                    <h2>Response Time</h2>
                    <p>We typically respond to inquiries within <strong>24–48 hours</strong> during business days. For urgent matters, please mention "URGENT" in the subject line of your email.</p>
                </div>
    </main>
    <script>import '../scripts/contact.js';</script>
</Layout>
